local function GiveBlock(name, remoteName, color)
    local tool = Instance.new("Tool")
    tool.Name = name
    tool.RequiresHandle = true
    tool.ToolTip = "Gerçek Block"
    
    local handle = Instance.new("Part")
    handle.Name = "Handle"
    handle.Size = Vector3.new(4, 4, 4)
    handle.Material = Enum.Material.Neon
    handle.Color = color
    handle.Parent = tool
    
    local mesh = Instance.new("SpecialMesh")
    mesh.MeshType = Enum.MeshType.FileMesh
    mesh.MeshId = "rbxassetid://6686405894"
    mesh.Scale = Vector3.new(2, 2, 2)
    mesh.Parent = handle
    
    tool.Parent = LocalPlayer.Backpack
    
    tool.Activated:Connect(function()
        if tool.Parent == LocalPlayer.Character then
            local remote = RS:FindFirstChild(remoteName)
            if remote then remote:FireServer() end
            tool:Destroy()
        end
    end)
end

local function GiveVoidBlock()
    local tool = Instance.new("Tool")
    tool.Name = "Void Lucky Block"
    tool.RequiresHandle = true
    tool.ToolTip = "Void Block - 10x Item"
    
    local handle = Instance.new("Part")
    handle.Name = "Handle"
    handle.Size = Vector3.new(4.3, 4.3, 4.3)
    handle.Material = Enum.Material.ForceField
    handle.Color = Color3.fromRGB(15, 15, 30)
    handle.Parent = tool
    
    local mesh = Instance.new("SpecialMesh")
    mesh.MeshType = Enum.MeshType.FileMesh
    mesh.MeshId = "rbxassetid://6686405894"
    mesh.Scale = Vector3.new(2.2, 2.2, 2.2)
    mesh.Parent = handle
    
    local light = Instance.new("PointLight")
    light.Color = Color3.fromRGB(120, 0, 255)
    light.Brightness = 4
    light.Range = 20
    light.Parent = handle
    
    tool.Parent = LocalPlayer.Backpack
    
    tool.Activated:Connect(function()
        if tool.Parent == LocalPlayer.Character then
            local remote = RS:FindFirstChild("SpawnVoidBlock") or RS:FindFirstChild("VoidBlock")
            if remote then
                for i = 1, 10 do
                    remote:FireServer()
                    wait(0.08)
                end
            else
                local main = RS:FindFirstChild("SpawnLuckyBlock")
                if main then 
                    for i = 1, 10 do
                        main:FireServer()
                        wait(0.08)
                    end
                end
            end
            tool:Destroy()
        end
    end)
end

